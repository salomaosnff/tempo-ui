{
  "name": "@tempoui/core",
  "version": "1.0.0",
  "description": "A premium component library built with tsdown",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.vue"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./*": {
      "types": "./dist/*/*.d.ts",
      "import": "./dist/*/*.js",
      "require": "./dist/*/*.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "NODE_ENV=production tsdown && tsx scripts/postbuild.ts",
    "prepublishOnly": "pnpm run build",
    "watch": "tsdown --watch",
    "check": "vue-tsc -p tsconfig.check.json --noEmit",
    "size": "size-limit"
  },
  "keywords": [
    "components",
    "library",
    "typescript",
    "tsdown"
  ],
  "author": "Antigravity",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@regle/core": "^1.21.8",
    "@regle/rules": "^1.21.8",
    "@size-limit/preset-small-lib": "^12.0.1",
    "@tsdown/css": "^0.21.7",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "oxlint": "^1.59.0",
    "size-limit": "^12.0.1",
    "tsc-alias": "^1.8.16",
    "tsdown": "^0.21.7",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "unplugin-vue": "^7.1.1",
    "vite": "^8.0.8",
    "vue": "^3.5.32",
    "vue-tsc": "^3.2.6"
  },
  "peerDependencies": {
    "@regle/core": "^1.21.8",
    "vue": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@regle/core": {
      "optional": true
    }
  },
  "dependencies": {
    "lodash-es": "^4.18.1"
  }
}