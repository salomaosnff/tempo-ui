{
  "name": "@tempoui/core",
  "version": "1.0.0",
  "description": "A premium component library built with tsdown",
  "keywords": [
    "components",
    "library",
    "tsdown",
    "typescript"
  ],
  "license": "MIT",
  "author": "Antigravity",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "**/*.vue"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json",
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "build": "NODE_ENV=production vp pack && tsx scripts/postbuild.ts",
    "prepublishOnly": "pnpm run build",
    "watch": "vp pack --watch",
    "check": "vue-tsc -p tsconfig.check.json --noEmit",
    "size": "size-limit",
    "test": "vp test run",
    "test:watch": "vp test"
  },
  "dependencies": {
    "lodash-es": "catalog:"
  },
  "devDependencies": {
    "@regle/core": "catalog:",
    "@regle/rules": "catalog:",
    "@size-limit/preset-small-lib": "^12.0.1",
    "@tsconfig/node24": "^24.0.4",
    "@tsdown/css": "^0.21.7",
    "@types/lodash-es": "catalog:",
    "@types/node": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "@vue/tsconfig": "catalog:",
    "size-limit": "^12.0.1",
    "tsc-alias": "^1.8.16",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "unplugin-vue": "^7.1.1",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "vue": "catalog:",
    "vue-tsc": "catalog:"
  },
  "peerDependencies": {
    "@regle/core": "catalog:",
    "vue": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@regle/core": {
      "optional": true
    }
  },
  "packageManager": "pnpm@10.33.0",
  "inlinedDependencies": {
    "@vueuse/core": "14.2.1",
    "@vueuse/shared": "14.2.1"
  }
}
